#define PI 3.1415926535897932384626433832795
#define kRefWhiteLevel 100.0 //in-the-spec, SDR 1.0 = 100 nits
#define kSdrWhiteLevel 300.0 //"Common" SDR TVs usually interpret 1.0 to 250-400 nits.

//Using higher-precision calculated gamut conversion matrices instead of values from the spec
//#define MORE_CONSTANT_FLOAT_DIGITS 1

//To void re-calculation everytime in the shader
#define PQ_100NITS	0.508078421 //PQ_OETF(1.0)

#ifndef M_INF
#define M_INF (1.0/0.0)
#endif

#define Hdr2SdrTonemap ReinhardTonemap

float3 ReinhardTonemap(float3 orig)
{
	orig = clamp(orig, 0.0, M_INF); //ensure all-positive inputs
	return orig / (float3(1.0) + orig);
}
