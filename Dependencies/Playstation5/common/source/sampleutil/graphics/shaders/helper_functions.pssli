float4 SRGB_OETF(float4 L)
{
	float3 dark = L.xyz * 12.92;
    float3 light = 1.055 * (float3)pow(L.xyz, 1.0 / 2.4) - 0.055;

    float4 r;
	bool3 cri = L.xyz <= 0.0031308;
	r.x = CndMask(cri.x, dark.x, light.x);
	r.y = CndMask(cri.y, dark.y, light.y);
	r.z = CndMask(cri.z, dark.z, light.z);
	r.w = L.w;
    return r;
}

float4 SRGB_EOTF(float4 E)
{
	float3 dark = E.xyz/12.92;
	float3 light = pow((E.xyz+0.055)/(1+0.055), 2.4);
	float4 r;
	bool3 cri = E.xyz <= 0.04045;
	r.x = CndMask(cri.x, dark.x, light.x);
	r.y = CndMask(cri.y, dark.y, light.y);
	r.z = CndMask(cri.z, dark.z, light.z);
	r.w = E.w;
	return r;
}

float4	BT1886_OETF(float4	L)
{
	float	gamma = 2.2f;
	float	Lw = 1.f;
	float	Lb = 0.f;
	// The reference EOTF specified in Rec. ITU-R BT.1886
	// L = a(max[(V+b),0])^g
	float	a = pow(pow(Lw, 1.f / gamma) - pow(Lb, 1.f / gamma), gamma);
	float	b = pow(Lb, 1.f / gamma) / (pow(Lw, 1.f / gamma) - pow(Lb, 1.f / gamma));
	float4	V = float4(pow(max(L.rgb / a, 0.f), 1.f / gamma) - b, L.a);
	return	V;
}

//apply BT.2100 OOTF to (minL, maxL).
float4 BT2100_OOTF(float4 L, float minLNits, float maxLNits, float gamma, bool inverse)
{
	float3 nits = L.xyz * kRefWhiteLevel;
	bool3 cri = nits >= minLNits && nits < maxLNits;
	float4 i = float4((nits - minLNits) / (maxLNits - minLNits), 1.0);
	float3 j; 
	if(inverse){
		j = SRGB_EOTF(pow(i, 1/gamma)).xyz;
	}else{
		j = pow( SRGB_OETF(i).xyz, gamma);
	}
	float3 adj =  (minLNits + (maxLNits - minLNits) * j) / kRefWhiteLevel;
	float4 ret;
	ret.x = CndMask(cri.x, adj.x, L.x);
	ret.y = CndMask(cri.y, adj.y, L.y);
	ret.z = CndMask(cri.z, adj.z, L.z);
	ret.w = L.w;
	return ret;
}

//constants for PQ calculations
static const float c1 = 0.8359375;//3424.f/4096.f;
static const float c2 = 18.8515625;//2413.f/4096.f*32.f;
static const float c3 = 18.6875; //2392.f/4096.f*32.f;
static const float m1 = 0.1593017578125; //2610.f / 4096.f / 4;
static const float m2 = 78.84375;// 2523.f / 4096.f * 128.f;


//input: normalized L in units of RefWhite (1.0=100nits), output: normalized E
float4 PQ_OETF(float4 L, uint ootf_adj = 0, float gamma = 2.2)
{
	if(ootf_adj)
		L = BT2100_OOTF(L, 0.0, 300.0, gamma, false);
	L.xyz = L.xyz * kRefWhiteLevel / 10000.0; 
	float3 Lm1 = pow(L.xyz, m1);
	float3 X = (c1 + c2 * Lm1) / (1 + c3 * Lm1);
	float4 res = float4(pow(X, m2), L.w);
	return res;
}

//input: normalized E (0.0, 1.0), output: normalized L in units of RefWhite
float4 PQ_EOTF(float4 E, uint ootf_adj = 0, float gamma = 2.2)
{
	float3 M = c2 - c3 * pow(E.xyz, 1/m2);
	float3 N = max(pow(E.xyz,1/m2)-c1, 0);
	float3 L = pow(N/M, 1/m1); //normalized nits (1.0 = 10000nits)
	L = L * 10000.0 / kRefWhiteLevel; //convert to normalized L in units of RefWhite
	return ootf_adj ? BT2100_OOTF(float4(L, E.w), 0.0, 300.0, gamma, true) : float4(L, E.w);

}

bool2	isOdd(float2	val)
{
	return ((int2)val) & 1;
}

#if defined ( __PROSPERO__ )
template<typename T>
T	croppedSample(Texture2D<T>	tex, sce::Agc::Core::Sampler	sampler, float2	uv, float2	minUv, float2	maxUv)
{
	uint2	dims;
	tex.GetDimensionsFast(dims.x, dims.y);

	float2	unnormalizedUv = uv;
	if (sampler.getTextureCoordinates()	== sce::Agc::Core::Sampler::TextureCoordinates::kAuto)
	{
		unnormalizedUv *= (float2)dims;
		minUv *= (float2)dims;
		maxUv *= (float2)dims;
		sampler.setTextureCoordinates(sce::Agc::Core::Sampler::TextureCoordinates::kUnnormalized);
	}

	bool2	isMirror(sampler.getWrapModeX() == sce::Agc::Core::Sampler::WrapMode::kMirror, sampler.getWrapModeY() == sce::Agc::Core::Sampler::WrapMode::kMirror);

	float2	modUv	= fmod(unnormalizedUv, float2(dims));
	modUv =	(isMirror && isOdd(floor(modUv))) ?	(float)dims	- modUv	: modUv;
	float2	uvAdjust = max(ceil(minUv) + 0.5f - modUv, 0.f) + min(floor(maxUv) - 0.5f - modUv, 0.f);
	unnormalizedUv += isMirror ? -uvAdjust : uvAdjust;

	return	tex.Sample(SamplerState(sampler), unnormalizedUv);
}
#endif